datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

model Organization {
  code                String   @id
  name                String
  level               String   // "province" | "city" | "municipality" | "barangay"
  emailDomain         String?
  customDomain        String?
  usesGoogleWorkspace Boolean  @default(false)
  createdAt           DateTime @default(now())

  departments  Department[]
  staff        StaffUser[]
  invites      StaffInvite[]
  citizens     CitizenUser[]
  applications ApplicationCase[]
  auditLogs    AuditLog[]
}

model Department {
  id       String   @id @default(uuid())
  orgCode  String
  org      Organization @relation(fields: [orgCode], references: [code])
  name     String
  category String   // "mandatory" | "optional" | "custom"

  staff        StaffUser[]
  applications ApplicationCase[]

  @@index([orgCode])
}

model StaffUser {
  id           String   @id @default(uuid())
  orgCode      String
  org          Organization @relation(fields: [orgCode], references: [code])
  email        String   @unique
  passwordHash String?  // nullable — Google OAuth users may have none
  authProvider String   @default("password") // "password" | "google"
  status       String   @default("active")   // "active" | "suspended"
  baseRole     String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  createdAt    DateTime @default(now())

  employee     Employee?
  grants       PermissionGrant[]
  invitesSent  StaffInvite[] @relation("InvitedBy")
  auditLogs    AuditLog[]

  @@index([orgCode])
}

model StaffInvite {
  id          String   @id @default(uuid())
  orgCode     String
  org         Organization @relation(fields: [orgCode], references: [code])
  email       String
  invitedById String
  invitedBy   StaffUser @relation("InvitedBy", fields: [invitedById], references: [id])
  status      String   @default("pending") // "pending" | "accepted" | "revoked" | "expired"
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([orgCode])
}

model Employee {
  id          String   @id @default(uuid())
  staffUserId String   @unique
  staffUser   StaffUser @relation(fields: [staffUserId], references: [id])
  position    String
  dateHired   DateTime
}

model PermissionGrant {
  id          String   @id @default(uuid())
  staffUserId String
  staffUser   StaffUser @relation(fields: [staffUserId], references: [id])
  permission  String   // e.g. "manage_hr", "review_ordinance", "approve_permits"
  scopeType   String   // "department" | "case" | "org"
  scopeId     String
  createdAt   DateTime @default(now())
}

model CitizenUser {
  id                String   @id @default(uuid())
  orgCode           String
  org               Organization @relation(fields: [orgCode], references: [code])
  email             String?  @unique
  phone             String?  @unique
  passwordHash      String
  fullName          String
  verificationLevel String   @default("unverified") // "unverified" | "id_verified"
  philsysNumberHash String?  @unique
  createdAt         DateTime @default(now())

  applications ApplicationCase[]

  @@index([orgCode])
}

model ServiceType {
  code                 String   @id
  name                 String
  category             String   // "barangay" | "municipal" | "provincial"
  requiresVerification Boolean  @default(false)

  applications ApplicationCase[]
}

model ApplicationCase {
  id                   String   @id @default(uuid())
  orgCode              String
  org                  Organization @relation(fields: [orgCode], references: [code])
  citizenId            String
  citizen              CitizenUser @relation(fields: [citizenId], references: [id])
  serviceTypeCode      String
  serviceType          ServiceType @relation(fields: [serviceTypeCode], references: [code])
  status               String   @default("submitted") // "submitted" | "in_review" | "approved" | "rejected"
  assignedDepartmentId String?
  assignedDepartment   Department? @relation(fields: [assignedDepartmentId], references: [id])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([orgCode])
}

model AuditLog {
  id         String   @id @default(uuid())
  orgCode    String?
  org        Organization? @relation(fields: [orgCode], references: [code])
  actorId    String?
  actor      StaffUser? @relation(fields: [actorId], references: [id])
  actorEmail String
  action     String   // "login_success" | "login_failed" | "account_suspended"
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([orgCode])
  @@index([actorId])
}
